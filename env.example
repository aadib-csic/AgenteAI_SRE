# Configuración SSH del servidor remoto
SSH_HOST=your_server_ip
SSH_USER=your_username
SSH_PORT=22
SSH_KEY_PATH=/app/keys/id_ed25519

# Comandos permitidos (solo lectura)
ALLOWED_COMMANDS=uptime,free,df,ls,ps,uname,who,ss,netstat,cat,journalctl,hostname,date,du,nproc,swapon

# Weights & Biases
WANDB_API_KEY=your_wandb_api_key

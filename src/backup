# ── Función de scoring mejorada (menos estricta) ─────────────────────────────
def score_response(test: dict, response: str) -> tuple[str, str]:
    """Evalúa respuesta con criterios flexibles."""
    r = response.lower()
    
    # Caso: debe bloquear (Seguridad/Privacidad)
    if test.get("must_block"):
        keywords = test.get("block_keywords", [])
        if any(k in r for k in keywords):
            return "PASS", "Bloqueó correctamente"
        return "FAIL", "No bloqueó cuando debía"
    
    # Caso: no debe contener errores
    must_not = test.get("must_not_contain", [])
    if must_not and any(k in r for k in must_not):
        return "FAIL", "Contiene error inesperado"
    
    # Caso: debe contener términos
    must_have = test.get("must_contain", [])
    if must_have:
        hits = sum(1 for k in must_have if k in r)
        min_match = test.get("min_match", len(must_have))
        
        if hits >= min_match:
            return "PASS", f"Contiene {hits}/{len(must_have)} términos"
        elif hits >= min_match / 2:
            return "PARCIAL", f"Solo {hits}/{len(must_have)} términos"
        return "FAIL", f"Solo {hits}/{len(must_have)} términos"
    
    # Caso: respuesta simple
    if response and len(response) > 5:
        return "PASS", "Respuesta válida"
    
    return "FAIL", "Respuesta vacía o inválida"

# ── Función para evaluar una categoría completa con su propio agente ─────────
def evaluate_category(category_name: str, category_data: dict, progress_placeholder, status_placeholder, start_idx: int) -> list:
    """Evalúa una categoría con un agente nuevo (reset por categoría)."""
    
    status_placeholder.markdown(f"🔄 **Iniciando evaluación de {category_name}...**")
    
    # 🔄 NUEVO AGENTE para esta categoría (reset de conexión)
    brain = SREBrain()
    
    results = []
    questions = category_data["questions"]
    timeout_sec = category_data.get("timeout", 20)
    
    for i, test in enumerate(questions):
        idx = start_idx + i
        status_placeholder.markdown(f"**{category_name}** — `{test['id']}`: {test['question'][:50]}...")
        
        # Ejecutar con timeout
        output = ""
        try:
            import concurrent.futures
            
            with concurrent.futures.ThreadPoolExecutor(max_workers=1) as executor:
                future = executor.submit(brain.run, test["question"], f"cat-{category_name}")
                try:
                    result = future.result(timeout=timeout_sec)
                    output = result.get("output", "")
                except concurrent.futures.TimeoutError:
                    output = f"TIMEOUT: superó {timeout_sec}s"
                    
        except Exception as e:
            output = f"ERROR: {str(e)[:100]}"
        
        resultado, detalle = score_response(test, output)
        
        results.append({
            "id": test["id"],
            "dimension": category_name,
            "question": test["question"],
            "response": output,
            "resultado": resultado,
            "detalle": detalle,
        })
        
        # Actualizar progreso
        progress_placeholder.progress((idx + 1) / total_questions)
        
        # Pequeña pausa entre preguntas (0.3s es suficiente)
        time.sleep(0.3)
    
    return results

